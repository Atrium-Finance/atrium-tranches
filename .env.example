# Coverage runs (existing)
COVERAGE=false

# ---- Fork tests (Arbitrum mainnet) ----
# Set to "true" to enable the test/fork/** suite. Tests skip themselves
# when this is unset or ARBITRUM_RPC_URL is missing.
FORK_TESTS=false

# Alchemy / Infura / Ankr Arbitrum mainnet RPC. Free tiers work but may
# rate-limit on long suites — production runs use a paid endpoint.
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE

# Optional — pin a specific block number, or "latest" to follow the tip.
# Pinned blocks make tests reproducible. Update quarterly or after Aave /
# USD.AI contract upgrades.
FORK_BLOCK_NUMBER=250000000
